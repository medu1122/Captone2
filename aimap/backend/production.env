# Production API keys for Docker deployment — loaded by docker-compose via env_file
# After git pull on VPS, run setup-keys.sh to fill these in (or edit manually)
OPENAI_API_KEY=REPLACE_WITH_YOUR_KEY
OPENAI_IMAGE_MODEL=gpt-image-1
GEMINI_API_KEY=
GEMINI_IMAGEN_MODEL=imagen-3.0-generate-002
GEMINI_IMAGE_MODEL=gemini-2.5-flash-preview-05-20
